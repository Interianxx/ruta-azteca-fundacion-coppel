# ─────────────────────────────────────────────────────────────────
# .env.example — Copia esto a .env.local y rellena los valores
# Obtén los valores de Terraform: terraform output -chdir=infra
# ─────────────────────────────────────────────────────────────────

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_JWKS_URI=

# DynamoDB
DYNAMODB_TABLE_NAME=

# S3 / CloudFront
S3_BUCKET_NAME=
CLOUDFRONT_URL=

# Lambdas
LAMBDA_CHATBOT_NAME=
LAMBDA_TRADUCCION_NAME=
LAMBDA_VOZ_NAME=

# Mapbox — https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=
